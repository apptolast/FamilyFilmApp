# composeApp/fastlane/.env.example
#
# Copy this file to `composeApp/fastlane/.env` (gitignored) and fill in the
# values. fastlane-dotenv (bundled with fastlane 2.x) loads `.env` automatically
# so anything declared here becomes an env var for every lane in this folder.
#
# In CI we don't use a .env file: the workflow exports these as job-level env
# vars, populated from GitHub Actions Secrets.

# Absolute path to the Play Console service account JSON key file.
# Create it at: Google Cloud Console → IAM → Service Accounts → Keys → Add JSON.
# The same account must be granted "Release manager" access on the app inside
# Play Console → Setup → API access.
SUPPLY_JSON_KEY=/absolute/path/to/play-service-account.json
