# iosApp/fastlane/.env.example
#
# Copy this file to `iosApp/fastlane/.env` (gitignored) and fill in the values
# so fastlane-dotenv loads them automatically when you run any lane in this
# folder. In CI we don't use a .env file: the workflow exports these as
# job-level env vars, populated from GitHub Actions Secrets.

# ---------------------------------------------------------------------------
# Apple Developer / App Store Connect identity
# ---------------------------------------------------------------------------

# Apple ID email used to sign in to App Store Connect (read by `pilot` and
# `deliver`). Only required for interactive sessions — CI prefers the
# App Store Connect API key below, which is non-interactive.
APPLE_ID=you@example.com

# Apple Developer Team ID (developer.apple.com → Membership → Team ID).
# Used by `match`, `gym`, and `produce` to scope provisioning.
FASTLANE_TEAM_ID=ABCDE12345

# App Store Connect Team ID (App Store Connect → Users and Access → Team ID).
# Distinct from the developer team id above; needed by `pilot` and `deliver`.
FASTLANE_ITC_TEAM_ID=987654321

# ---------------------------------------------------------------------------
# App Store Connect API key (preferred over Apple ID + 2FA in CI)
# ---------------------------------------------------------------------------
# Generate at: App Store Connect → Users and Access → Keys → App Store Connect API
# Roles required: at least "Developer" for TestFlight uploads, "App Manager"
# for App Store submissions.

APP_STORE_CONNECT_API_KEY_ID=ABCDEF1234
APP_STORE_CONNECT_API_KEY_ISSUER_ID=12345678-1234-1234-1234-123456789012
# Absolute path to the .p8 file downloaded from App Store Connect.
APP_STORE_CONNECT_API_KEY_PATH=/absolute/path/to/AuthKey_ABCDEF1234.p8

# ---------------------------------------------------------------------------
# match (signing certificates + provisioning profiles)
# ---------------------------------------------------------------------------
# `match` stores signing artifacts encrypted in a private Git repo (or S3
# bucket). The password decrypts the contents; the URL points at the repo
# holding the App Store profile + distribution certificate.

MATCH_GIT_URL=https://github.com/apptolast/ios-certificates.git
MATCH_PASSWORD=replace-me-with-a-strong-passphrase

# When pulling the match repo from GitHub Actions, use a PAT via Basic auth:
#   echo -n "username:PAT" | base64
# Stored as `MATCH_GIT_BASIC_AUTHORIZATION` secret.
MATCH_GIT_BASIC_AUTHORIZATION=
